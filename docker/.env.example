# =============================================================================
# Environment Variables for Docker Compose
# Copy this file to .env and modify as needed
# =============================================================================

# SQL Server password (used by Service Bus emulator)
# Must meet SQL Server password requirements:
# - At least 8 characters
# - Contains uppercase, lowercase, numbers, and symbols
# Note: Avoid special characters like @ that may cause issues
MSSQL_SA_PASSWORD=SqlPassw0rd2025

# Optional: Cosmos DB partition count (default: 10)
# AZURE_COSMOS_EMULATOR_PARTITION_COUNT=10

# UI reverse-proxy API protection. The UI container requires HTTP Basic auth
# before forwarding /api/ requests to the Functions container.
UI_BASIC_AUTH_USERNAME=demo-admin
UI_BASIC_AUTH_PASSWORD=ChangeThisDemoPassword2025!

# Must match docker/config/secrets/host.json for the Functions host.
ORCHESTRATION_FUNCTION_KEY=demoFunctionKey12345678901234567890123456
